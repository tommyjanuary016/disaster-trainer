# ================================================================
# 災害医療訓練システム - Firebase 設定ファイル
# ================================================================
# このファイルを .env.local にコピーして使用してください。
# ファイル名: .env.local（.gitignore に含まれており、Git管理外）
#
# 【取得方法】
# 1. https://console.firebase.google.com でプロジェクトを作成
# 2. 「プロジェクトの設定」→「マイアプリ」→「ウェブアプリ追加」
# 3. 「SDK の設定と構成」から以下の値をコピー
# ================================================================

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# ================================================================
# Firestore セキュリティルール（Firebase コンソールで設定）
# ================================================================
# 以下のルールを Firebase コンソール > Firestore > ルール に貼り付けてください:
#
# rules_version = '2';
# service cloud.firestore {
#   match /databases/{database}/documents {
#     match /{document=**} {
#       allow read, write: if true;  // 訓練用（本番運用では要認証設定）
#     }
#   }
# }
# ================================================================

# モードの切替
# true  → モックモード（Firebaseなし・端末内だけで動作）
# false → Firebase本番モード（多端末リアルタイム同期）
VITE_USE_MOCK=false
